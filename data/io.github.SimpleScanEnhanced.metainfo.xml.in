<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.SimpleScanEnhanced</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0+</project_license>
  <name>Document Scanner Enhanced</name>
  <summary>Scan, auto-straighten, and auto-crop your documents</summary>
  <description>
    <p>
      An enhanced fork of GNOME Document Scanner (simple-scan) with built-in
      automatic document straightening and cropping. Tuned for letter-sized
      white pages on a scanner whose background reads as black.
    </p>
    <p>
      Auto-crop is enabled by default; auto-straighten is opt-in. Both can be
      toggled in the Postprocessing section of Preferences. The detected crop
      is applied through the existing Custom Crop tool, so it remains fully
      adjustable per page.
    </p>
    <p>
      Like its upstream, this app uses the SANE framework to support most
      existing scanners.
    </p>
  </description>
